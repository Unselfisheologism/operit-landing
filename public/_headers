# ═══════════════════════════════════════════════════════
# CLOUDFLARE PAGES — SECURITY HEADERS
# SSL/HTTPS Enforcement + Mixed Content Protection
# ═══════════════════════════════════════════════════════

/*
  # ─── SSL / HSTS ──────────────────────────────────────
  # Tell browsers to ALWAYS use HTTPS for this origin
  # includeSubDomains = apply to all subdomains (cdn.twent.xyz, etc.)
  # preload = submit to browser HSTS preload list (hstspreload.org)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # ─── Content Security Policy ──────────────────────────
  # Block ALL mixed content, force HTTPS for all resources
  # 'self' = same origin (twent.xyz)
  # upgrade-insecure-requests = auto-upgrade http:// → https://
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://fonts.googleapis.com https://cdn.databuddy.cc https://static.cloudflareinsights.com https://static.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdn.tailwindcss.com https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; img-src 'self' data: https://twent.xyz https://pub-84df04198c6b46f19ce9ed18d378ff7e.r2.dev https://*.r2.dev https://pbs.twimg.com https://abs.twimg.com https://cdn.sstatic.net https://lh3.googleusercontent.com; connect-src 'self' https://api.databuddy.io https://twent.xyz https://static.cloudflareinsights.com https://cadlhnfgxvyzfddmchxw.supabase.co https://www.googletagmanager.com https://www.google-analytics.com; frame-src 'self' https://www.youtube.com https://youtube.com; media-src 'self' https://pub-84df04198c6b46f19ce9ed18d378ff7e.r2.dev; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

  # ─── Clickjacking Protection ──────────────────────────
  # Only allow embedding in iframes from same origin
  X-Frame-Options: SAMEORIGIN

  # ─── MIME Type Sniffing ───────────────────────────────
  # Prevent browsers from guessing content types (security risk)
  X-Content-Type-Options: nosniff

  # ─── Referrer Privacy ─────────────────────────────────
  # Only send full referrer to same-origin, strip to origin for HTTPS→HTTPS,
  # and never send for HTTPS→HTTP
  Referrer-Policy: strict-origin-when-cross-origin

  # ─── Browser Feature Permissions ─────────────────────
  # Disable risky browser APIs that could be abused
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=()

  # ─── XSS Filter (legacy browsers) ─────────────────────
  X-XSS-Protection: 1; mode=block

  # ─── CORS ─────────────────────────────────────────────
  Access-Control-Allow-Origin: https://twent.xyz

  # ─── HTML Edge Caching (FIX: Core Web Vitals) ─────────
  # Previous: max-age=0; must-revalidate — EVERY request hit origin = 5s LCP
  # Fix: Cache HTML at Cloudflare edge for 5 minutes, serve stale while revalidating
  # This reduces TTFB from 730ms→50ms (cached) and eliminates p95 3100ms spikes
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=86400

